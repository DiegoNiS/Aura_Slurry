# Aura-Slurry Environment Variables

# Configuración del Servidor Backend
HOST=0.0.0.0
PORT=8000
FRONTEND_URL=*

# Gemini 2.5 Flash API Key para el Agente Recomendador
# Consigue una en: https://aistudio.google.com/
GEMINI_API_KEY="TU_API_KEY_AQUI"

# Reportes a la minera por correo (opcionales — sin esto solo se muestran
# en el dashboard). Para Gmail: crear una "contraseña de aplicación".
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=cuenta@gmail.com
SMTP_PASS=contraseña-de-aplicacion
REPORT_EMAIL_TO=supervisor@minera.com, equipo@aura.com

# Umbral del reporte: N ventanas FALLA en la ventana de observación
REPORT_FAILURE_THRESHOLD=8
REPORT_WINDOW_SECONDS=60
REPORT_COOLDOWN_SECONDS=180
