# Aura-Slurry Frontend - Environment Variables
# 
# Copia este archivo a ".env" o ".env.local" para desarrollo local.
# Para despliegue (ej. Vercel), configura estas variables en el panel de control.

# URL base para la API REST del backend
# Local: http://localhost:8000
# Prod:  https://tu-backend.onrender.com
VITE_API_BASE_URL=http://localhost:8000

# URL base para los WebSockets del backend
# Local: ws://localhost:8000
# Prod:  wss://tu-backend.onrender.com
VITE_WS_BASE_URL=ws://localhost:8000
